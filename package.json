{
  "name": "latrodectus-gn",
  "version": "1.0.0",
  "description": "Latrodectus GN build system with patch management",
  "scripts": {
    "init": "node scripts/init.js",
    "sync": "node scripts/sync.js",
    "build": "node scripts/build.js",
    "update_patches": "node scripts/updatePatches.js",
    "apply_patches": "node scripts/applyPatches.js",
    "format": "node scripts/format.js",
    "deploy": "node scripts/deploy.js",
    "test": "python3 tests/run_tests.py",
    "test:verbose": "python3 tests/run_tests.py -v",
    "test:case": "python3 tests/run_tests.py -v",
    "test:debug": "python3 tests/run_tests.py -v --show-ninja --show-gn"
  },
